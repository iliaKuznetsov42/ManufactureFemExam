<Window x:Class="ManufactureFemExam.View.Windows.AddOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ManufactureFemExam.View.Windows"
        mc:Ignorable="d"
        Title="AddOrderPage" ResizeMode="NoResize"  SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="10*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Text="Номер"/>
        <TextBox Name ="NameOrderTb" Grid.Row="0" Grid.Column="2" Text="{Binding Number}"/>
        <TextBlock Grid.Row="3" Text="Цена"/>
        <TextBox Name ="PriceTb" Grid.Row="1" Grid.Column="2" Text="{Binding TotalPrice}"/>
        <TextBlock Grid.Row="1" Text="Дата"/>
        <DatePicker Name ="DateDp" Grid.Row="3" Grid.Column="2" Text="{Binding date}"/>

        <Button Name="EditOrderBtn"  Grid.Row="9" Grid.Column="2" Visibility="Hidden" Click="EditOrderBtn_Click"/>
        <Button Name="AddPOrderBtn" Content="Добавить заказ" Grid.Row="11" Grid.Column="2" Visibility="Visible" Click="AddPOrderBtn_Click"/>
    </Grid>
</Window>
