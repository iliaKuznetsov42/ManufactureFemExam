<Window x:Class="ManufactureFemExam.View.Windows.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ManufactureFemExam.View.Windows"
        mc:Ignorable="d"
        Title="AddProductWindow" ResizeMode="NoResize"  SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="10*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Text="Название"/>
        <TextBox Name ="NameProductTb" Grid.Row="0" Grid.Column="2" Text="{Binding Name}"/>
        <TextBlock Grid.Row="1" Text="Цена"/>
        <TextBox Name ="PriceTb" Grid.Row="1" Grid.Column="2" Text="{Binding Price}"/>
        <TextBlock Grid.Row="3" Text="Единица измерения"/>
        <ComboBox Name ="UnitCmb" Grid.Row="3" Grid.Column="2" Text="{Binding Unit.Name}"/>


        <Button Name="EditProductBtn"  Grid.Row="12" Grid.Column="2" Visibility="Hidden" Click="EditProductBtn_Click"/>
        <Button Name="AddProductBtn" Content="Добавить Продукт" Grid.Row="11" Grid.Column="2" Visibility="Visible" Click="AddProductBtn_Click"/>
    </Grid>
</Window>
